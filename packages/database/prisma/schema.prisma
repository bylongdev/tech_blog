generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Source {
  id                   String       @id @default(cuid())
  name                 String
  url                  String?      @unique
  slug                 String       @unique
  fetchType            FetchType
  parserType           String       @default("default")
  fetchConfig          Json?
  category             String?
  enabled              Boolean      @default(true)
  fetchIntervalMinutes Int          @default(30)
  lastFetchedAt        DateTime?
  lastSuccessAt        DateTime?
  lastFailedAt         DateTime?
  failureCount         Int          @default(0)
  lastError            String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  fetchLogs            FetchLog[]
  articles             RawArticle[]
}

model RawArticle {
  id          String    @id @default(cuid())
  sourceId    String
  title       String
  link        String    @unique
  guid        String?
  summary     String?
  content     String?
  rawHtml     String?
  author      String?
  imageUrl    String[]
  publishedAt DateTime?
  fetchedAt   DateTime  @default(now())

  hash      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  source    Source   @relation(fields: [sourceId], references: [id])

  articleCandidate ArticleCandidate?

  @@unique([sourceId, guid])
  @@index([sourceId])
  @@index([publishedAt])
  @@index([hash])
}

model ArticleCandidate {
  id           String     @id @default(cuid())
  rawArticleId String     @unique
  rawArticle   RawArticle @relation(fields: [rawArticleId], references: [id])

  category    String?
  subCategory String?
  class       String?
  entities    String[]
  products    String[]
  event       String?
  summary     String?

  cleanedTitle  String
  embeddingText String
  embedding     Json?

  groupId String?
  group   ArticleGroup? @relation(fields: [groupId], references: [id])

  status CandidateStatus @default(QUEUED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupId])
}

model ArticleGroup {
  id String @id @default(cuid())

  candidates ArticleCandidate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  name         String?
  role         UserRole      @default(USER)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sessions     AuthSession[]
}

model AuthSession {
  id        String   @id @default(cuid())
  sid       String   @unique
  userId    String
  payload   String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model FetchLog {
  id             String      @id @default(cuid())
  sourceId       String
  status         FetchStatus
  startedAt      DateTime
  finishedAt     DateTime?
  itemsFound     Int?
  itemsProcessed Int?
  errorMessage   String?
  createdAt      DateTime    @default(now())
  source         Source      @relation(fields: [sourceId], references: [id])

  @@index([sourceId])
  @@index([status])
  @@index([startedAt])
}

enum FetchStatus {
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
}

enum FetchType {
  RSS
  HTML
  API
}

enum ConceptStatus {
  RAW
  FILTERED
  EMBEDDED
}

enum CandidateStatus {
  QUEUED
  EXTRACTED
  EMBEDDED
  GROUPED
  PROCESSED
  FAILED
}

enum UserRole {
  ADMIN
  USER
}
