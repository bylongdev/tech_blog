# Optional host port overrides used by Docker Compose.
FRONTEND_PORT=3000
BACKEND_PORT=4000
POSTGRES_PORT=5432
REDIS_PORT=6379

# Local service credentials. Replace every example value before exposing the
# stack outside a trusted development machine.
# Wrap values containing `$` in single quotes so Docker Compose does not treat
# part of the credential as an environment-variable reference.
POSTGRES_USER=techblog
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=techblog
DATABASE_URL=postgresql://techblog:change-me-postgres-password@postgres:5432/techblog

REDIS_PASSWORD=change-me-redis-password
SESSION_SECRET=change-me-to-a-random-string-at-least-32-characters-long

# Required when the worker processes OpenAI-backed jobs. It may remain empty
# when only the web application and infrastructure are being exercised.
OPENAI_API_KEY=
