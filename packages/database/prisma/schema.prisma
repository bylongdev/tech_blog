generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Source {
  id                   String       @id @default(cuid())
  name                 String
  url                  String?      @unique
  slug                 String       @unique
  fetchType            FetchType
  parserType           String       @default("default")
  fetchConfig          Json?
  category             String?
  enabled              Boolean      @default(true)
  fetchIntervalMinutes Int          @default(30)
  lastFetchedAt        DateTime?
  lastSuccessAt        DateTime?
  lastFailedAt         DateTime?
  failureCount         Int          @default(0)
  lastError            String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  fetchLogs            FetchLog[]
  articles             RawArticle[]
}

model RawArticle {
  id          String        @id @default(cuid())
  sourceId    String
  title       String
  link        String        @unique
  guid        String?
  summary     String?
  content     String?
  author      String?
  imageUrl    String?
  publishedAt DateTime?
  fetchedAt   DateTime      @default(now())
  hash        String?
  status      ArticleStatus @default(NEW)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  source      Source        @relation(fields: [sourceId], references: [id])

  @@unique([sourceId, guid])
  @@index([sourceId])
  @@index([status])
  @@index([publishedAt])
  @@index([hash])
}

model FetchLog {
  id            String      @id @default(cuid())
  sourceId      String
  status        FetchStatus
  startedAt     DateTime
  finishedAt    DateTime?
  itemsFound    Int?
  itemsInserted Int?
  errorMessage  String?
  createdAt     DateTime    @default(now())
  source        Source      @relation(fields: [sourceId], references: [id])

  @@index([sourceId])
  @@index([status])
  @@index([startedAt])
}

enum FetchStatus {
  SUCCESS
  FAILED
  PARTIAL
}

enum FetchType {
  RSS
  HTML
  API
}

enum ArticleStatus {
  NEW
  DUPLICATE
  QUEUED
  PROCESSED
  FAILED
}
